{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases */
    "paths": {
      "@/assets": ["./src/assets"],
      "@/assets/*": ["./src/assets/*"],
      "@/components": ["./src/components"],
      "@/components/*": ["./src/components/*"],
      "@/context": ["./src/context"],
      "@/context/*": ["./src/context/*"],
      "@/guards": ["./src/guards"],
      "@/guards/*": ["./src/guards/*"],
      "@/hooks": ["./src/hooks"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/lib": ["./src/lib"],
      "@/lib/*": ["./src/lib/*"],
      "@/pages": ["./src/pages"],
      "@/pages/*": ["./src/pages/*"],
      "@/sections": ["./src/sections"],
      "@/sections/*": ["./src/sections/*"],
      "@/styles": ["./src/styles"],
      "@/styles/*": ["./src/styles/*"],
      "@/types": ["./src/types"],
      "@/types/*": ["./src/types/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
